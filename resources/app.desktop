[Desktop Entry]
Name=Caffeine
Comment=Keep your screen awake — a caffeine applet for the COSMIC desktop
Type=Application
Icon=com.github.bgub.CosmicExtAppletRedbull
Exec=cosmic-ext-applet-redbull %F
Terminal=false
StartupNotify=true
Categories=COSMIC
Keywords=COSMIC;caffeine;screen;awake;inhibit
NoDisplay=true
X-CosmicApplet=true
X-CosmicHoverPopup=Auto
MimeType=
